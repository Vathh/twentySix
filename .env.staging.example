# ============================================
# twentySix — STAGING / PRODUCTION (.env)
# Skopiuj na serwer jako .env i uzupełnij wartości.
# Dev lokalny: użyj .env.example
# ============================================

APP_NAME=twentySix
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://staging.example.com

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dartscore
DB_USERNAME=dartscore
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=123456
REVERB_APP_KEY=change-me-staging-key
REVERB_APP_SECRET=change-me-staging-secret
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_HOST=staging.example.com
REVERB_PORT=443
REVERB_SCHEME=https

# Laravel (PHP-FPM) publikuje eventy bezpośrednio do procesu Reverb — nie przez nginx/443
REVERB_BROADCAST_HOST=127.0.0.1
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

QUEUE_CONNECTION=database
CACHE_STORE=database

# Mobile app — Sanctum token TTL (dni, domyślnie 30)
# MOBILE_TOKEN_TTL_DAYS=30

# Rejestracja — wymagany prawdziwy SMTP (link weryfikacji email)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Opcjonalnie Redis (cache/sessions) — na start wystarczy database
# REDIS_HOST=127.0.0.1
